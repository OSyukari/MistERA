{
    "Events":{
        "list":[
            {
                "ID":"OnEnterRoom",
                "_trigger":"OnEnterRoom",
                "SelfValidator":{
                    "chara_conditions":
                    [
                        { "parameters":["isPlayer"] },
                        { "parameters":["hasActionPackageType","ActionPackage_PathTo", "true", "true"] }
                    ]
                },
                "events":[
                    {
                        "$type": "Event+EventEntry+EventEntry_Line, Assembly-CSharp",
                        "line": "Player OnEnterRoom!"
                    },
                    {
                        "$type": "Event+EventEntry+EventEntry_Line, Assembly-CSharp",
                        "line": "Event END",
                        "isLast": true
                    }
                ]
            },
            {
                "ID":"OnEnterRoom_interrupt",
                "trigger":"OnEnterRoom",
                "SelfValidator":{
                    "chara_conditions":
                    [
                        { "parameters":["isPlayer"] },
                        { "parameters":["hasActionPackageType","ActionPackage_PathTo", "true", "false"] }
                    ]
                },
                "TargetValidators":
                [
                    {
                        "refkey":"targets",
                        "baseScope":"AllCharaInSelfRoom_ExcludeSelf",
                        "minTargetCount":1
                    }
                ],
                "events":[
                    {
                        "$type": "Event+EventEntry+EventEntry_Question, Assembly-CSharp",
                        "label": "interruptSelf",
                        "question":"event_OnEnterRoom_interrupt_ev01",
                        "options":[
                            { "option": "event_OnEnterRoom_interrupt_ev01_op1", "isDefaultCancel":true, "Results":[ { "Type":"EventEnd" } ] },
                            { "option": "event_OnEnterRoom_interrupt_ev01_op2", 
                                "Results":
                                [ 
                                    { "Type":"InterruptAP_byType", "arguments":["self","ActionPackage_PathTo"] },
                                    { "Type":"JumpToLabel", "arguments":["","end"] } 
                                ] 
                            }
                        ]
                    },
                    {
                        "$type": "Event+EventEntry+EventEntry_Line, Assembly-CSharp",
                        "label": "end",
                        "isLast": true,
                        "line": "event_OnEnterRoom_interrupt_ev02"
                    }
                ]
            }
        ]
    },
    "Dictionary":
    {
        "Entries":
        {
            "default":
            {
                "event_OnEnterRoom_interrupt_ev01":"$self.name$在进入$self.room_name$时遇到了$targets.name$",
                "event_OnEnterRoom_interrupt_ev01_op1":"继续移动",
                "event_OnEnterRoom_interrupt_ev01_op2":"在此停下",
                "event_OnEnterRoom_interrupt_ev02":"$self.name$停下了脚步",
                "event_OnEnterRoom_interrupt_ev01_op2_tooltip":"将中断当前未处理完毕的移动指令",
                "event_isDefaultCancel_tooltip":"在当前界面的任意非按钮处按右键时也会自动选择该选项"
            }
        }
    }
}