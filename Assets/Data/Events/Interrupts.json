{
    "Events":{
        "list":[
            {
                "ID":"OnEnterRoom",
                "_trigger":"OnEnterRoom",
                "SelfValidator":{
                    "chara_conditions":
                    [
                        { "parameters":["isPlayer"] },
                        { "parameters":["hasActionPackageType","ActionPackage_PathTo", "true", "true"] }
                    ]
                },
                "events":[
                    {
                        "$type": "Event+EventEntry+EventEntry_Line, Assembly-CSharp",
                        "line": "Player OnEnterRoom!"
                    },
                    {
                        "$type": "Event+EventEntry+EventEntry_Line, Assembly-CSharp",
                        "line": "Event END",
                        "isLast": true
                    }
                ]
            },
            {
                "ID":"OnEnterRoom_interrupt",
                "trigger":"OnEnterRoom",
                "SelfValidator":{
                    "chara_conditions":
                    [
                        { "parameters":["isPlayer"] },
                        { "parameters":["hasActionPackageType","ActionPackage_PathTo", "true", "true"] }
                    ],
                    "_comment":"has ap true true, will return true even if ap pathTo end"
                },
                "TargetValidators":
                [
                    {
                        "refkey":"targets",
                        "baseScope":"AllCharaInSelfRoom_ExcludeSelf",
                        "minTargetCount":1
                    }
                ],
                "events":[
                    {
                        "$type": "Event+EventEntry+EventEntry_Branch, Assembly-CSharp",
                        "_comment":"silent branching. if branch failed to match any condition and jump away, go to next block leavingroom",
                        "options":[
                            { 
                                "_comment":"checkExecuted false is more strict than other way around. if match, goto interrupt self",
                                "self_chara_conditions": 
                                [
                                    { "parameters":["hasActionPackageType","ActionPackage_PathTo", "true", "false"] }
                                ],
                                "Results":[ { "Type":"JumpToLabel", "arguments":["","interruptSelf"] } ] 
                            },
                            { 
                                "_comment":"if previous fail, then it means true true, jumping to next event",
                                "Results":[ { "Type":"JumpToLabel", "arguments":["OnEnterRoom_interruptOthers",""] } ] 
                            }
                        ]
                    },
                    {
                        "$type": "Event+EventEntry+EventEntry_Question, Assembly-CSharp",
                        "label": "interruptSelf",
                        "question":"$self.name$ enters room and meet $targets.name$ in room",
                        "options":[
                            { "option": "keep moving", "Results":[ { "Type":"EventEnd" } ] },
                            { "option": "stop", 
                                "Results":
                                [ 
                                    { "Type":"InterruptAP_byType", "arguments":["self","ActionPackage_PathTo"] },
                                    { "Type":"JumpToLabel", "arguments":["","end"] } 
                                ] 
                            }
                        ]
                    },
                    {
                        "$type": "Event+EventEntry+EventEntry_Line, Assembly-CSharp",
                        "label": "end",
                        "line": "$self.name$ stopped moving",
                        "nextEventID":"OnEnterRoom_interruptOthers"
                    }
                ]
            },
            {
                "ID":"OnEnterRoom_interruptOthers",
                "SelfValidator":{
                    "chara_conditions":
                    [
                        { "parameters":["isPlayer"] }
                    ]
                },
                "TargetValidators":[
                    {
                        "refkey":"targets",
                        "baseScope":"AllCharaInSelfRoom_ExcludeSelf",
                        "minTargetCount":1,
                        "chara_conditions":[
                            { "parameters":["hasActionPackageType","ActionPackage_PathTo"] }
                        ],
                        "_comment":"hasActionPackageType without extra arguments default to true false"
                    }
                ],
                "events":[
                    {
                        "$type": "Event+EventEntry+EventEntry_Question, Assembly-CSharp",
                        "question":"$targets.name$ are leaving room",
                        "options":[
                            { "option": "let them be", "Results":[ { "Type":"EventEnd" } ] },
                            {   "option": "stop them", 
                                "Results":[ 
                                    { "Type":"InterruptAP_byType", "arguments":["targets","ActionPackage_PathTo"] },
                                    { "Type":"JumpToLabel", "arguments":["","end"] } ] }
                        ]
                    },
                    {
                        "$type": "Event+EventEntry+EventEntry_Line, Assembly-CSharp",
                        "label": "end",
                        "isLast":true,
                        "line": "$self.name$ called $targets.name$"
                    }
                ]
            }
        ]
    }
}