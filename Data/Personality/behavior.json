{
    "FindJobNodeRoots": {
        "list": [
            {
                "ID": "behavior_default",
                "nodes": [
                    {
                        "$type": "TryFindBirthLocation, Assembly-CSharp",
                        "Tags": [ "nsfw" ],
                        "_comment":"hardcoded job search behavior"
                    },
                    {
                        "$type": "TryFindRedressNode, Assembly-CSharp",
                        "evaluationHeuristic":"closest",
                        "filter": {
                            "checkBlacklist": true,
                            "skipPrivateRoom":false,
                            "searchJobList":false,
                            "searchNonJobList":true
                        }
                    },
                    {
                        "$type": "TryChangeLocaleNode, Assembly-CSharp"
                    },
                    {
                        "$type": "TryFindSleepNode, Assembly-CSharp",
                        "evaluationHeuristic":"ownership_Medium",
                        "filter": {
                            "matchCOMID":"com_furniture_sleep",
                            "checkBlacklist": false,
                            "skipPrivateRoom":false,
                            "searchJobList":false,
                            "searchNonJobList":true
                        }
                    },
                    {
                        "$type": "TryFindMealNode, Assembly-CSharp",
                        "evaluationHeuristic":"random",
                        "filter": {
                            "checkBlacklist": true,
                            "skipPrivateRoom":false,
                            "searchJobList":false,
                            "searchNonJobList":true
                        }
                    },
                    {
                        "$type": "TryFindPartyExplorationJob, Assembly-CSharp",
                        "_comment":"hardcoded job search behavior"
                    },
                    {
                        "$type": "TryFindJobByIDNode, Assembly-CSharp",
                        "Tags": [ "nsfw" ],
                        "randomChance": 0.5,
                        "cooldownHours": 4,
                        "cooldownID": "com_furniture_restroom",
                        "evaluationHeuristic":"closest",
                        "filter": {
                            "matchCOMID":"com_furniture_restroom",
                            "checkBlacklist": true,
                            "skipPrivateRoom":false,
                            "searchJobList":false,
                            "searchNonJobList":true
                        }
                    },
                    {
                        "$type": "TryFindScheduledJobNode, Assembly-CSharp",
                        "_comment":"hardcoded job search parameter"
                    },
                    {
                        "$type": "TryFindRestNode, Assembly-CSharp",
                        "evaluationHeuristic":"random",
                        "filter": {
                            "checkBlacklist": true,
                            "skipPrivateRoom":false,
                            "searchJobList":false,
                            "searchNonJobList":true
                        }
                    },
                    {
                        "$type": "TryFindPrivateRoomCleaning, Assembly-CSharp",
                        "evaluationHeuristic":"closest",
                        "filter": {
                            "matchCOMID":"com_job_cleaning",
                            "matchCOMTag":"production_cleaning",
                            "checkBlacklist": true,
                            "skipPrivateRoom":false,
                            "searchJobList":false,
                            "searchNonJobList":true
                        }
                    },
                    {
                        "$type": "TryStayInJailNode, Assembly-CSharp"
                    },
                    {
                        "$type": "TryFindNonJobByTagNode, Assembly-CSharp",
                        "evaluationHeuristic": "random",
                        "filter": {
                            "matchCOMTag":"recreation",
                            "checkBlacklist": true,
                            "skipPrivateRoom":true,
                            "searchJobList":false,
                            "searchNonJobList":true
                        }
                    },
                    {
                        "$type": "TryFindNonJobByTagNode, Assembly-CSharp",
                        "evaluationHeuristic": "random",
                        "filter": {
                            "matchCOMTag":"rest",
                            "checkBlacklist": false,
                            "skipPrivateRoom":false,
                            "searchJobList":false,
                            "searchNonJobList":true
                        }
                    }
                ]
            }
        ]
    }
}