                    {
                        "ID": "Interrupt",
                        "_comment": "trigger. Fires when anyone else executes AP in same room, check if Self action should be modified",
                        "_comment2": "Player is allowed to call interrupt on others, but response text will not display (results will get executed)",
                        "_comment3": "Relationship: [self] witnessing [target] action",
                        "_comment4": "fired when [target] start new action, or when [self] move into [target] room",
                        "_comment5": "any [self] tag must be preexisting",
                        "interruptSelfJob": true,
                        "variants": [
                            {
                                "_comment": "this variant triggers when a chara is doing something in same room as sleeping character but the action does not include sleeping chara. For direct disruption, its hardcoded.",
