                                    "requireSelfAction": false,
                                    "requireSelfStatusValue": {
                                        "statusID": "chara_status_sleeping",
                                        "operand": "lte",
                                        "value": 0.9
                                    }
                                },
                                "selfEventCall": "DisruptSleep",
                                "keepLooking": true
                            },
                            {
