{
    "Events": {
        "list": [
            {                
                "ID": "exp_event_combat_draw",
                "events": [
    {
        "$type": "Event+EventEntry+EventEntry_Branch, Events",
        "options":[
            {   
                "target_chara_conditions":
                {
                    "party":[{"parameters":["exists"]}]
                },
                "Results": [ { "Type":"JumpToLabel", "arguments":["","br_end"]} ] 
            },
            {   
                "option": "silent fail branch",
                "Results": [ { "Type":"JumpToLabel", "arguments":["","br_error"]} ] 
            }
        ]
    },
    {
        "$type": "Event+EventEntry+EventEntry_Line, Events",
        "label": "br_end",
        "line": "exp_event_combat_draw_ev01",
        "isLast": true
    },
    {
        "$type": "Event+EventEntry+EventEntry_Line, Events",
        "label": "br_error",
        "line": "exp_event_combat_draw_ev99",
        "isLast": true
    }
                ]
            },
{                
    "ID": "exp_event_combat_victory",
    "SelfValidator":{
        "chara_conditions":[
            {"parameters":["exists"]}
        ]
    },
    "events": [
    {
        "$type": "Event+EventEntry+EventEntry_Branch, Events",
        "options":[
            {   
                "self_chara_conditions":[
                    {"parameters":["isPlayer"]}
                ],
                "target_chara_conditions":
                {
                    "party":[{"parameters":["exists"]}],
                    "enemy":[{"parameters":["exists"]}]
                },
                "Results": [ { "Type":"JumpToLabel", "arguments":["","br_end"]} ] 
            },
            {   
                "option": "silent fail branch",
                "Results": [ { "Type":"JumpToLabel", "arguments":["","br_error"]} ] 
            }
        ]
    },
    {
        "$type": "Event+EventEntry+EventEntry_Line, Events",
        "label": "br_end",
        "_comment":"change event flag if quest related, then open trade menu and allow looting on enemy or allow looting specific loots",
        "line": "$party.name$击败了敌人",
        "isLast": true
    },
    {
        "$type": "Event+EventEntry+EventEntry_Line, Events",
        "label": "br_error",
        "line": "警告！由于内容缺失，该事件强制终止。",
        "isLast": true
    }
    ]
},
{                
    "ID": "exp_event_combat_defeat",
    "SelfValidator":{
        "chara_conditions":[
            {"parameters":["exists"]}
        ]
    },
    "events": [
    {
        "$type": "Event+EventEntry+EventEntry_Branch, Events",
        "options":[
            {   
                "self_chara_conditions":[
                    {"parameters":["isPlayer"]}
                ],
                "target_chara_conditions":
                {
                    "party":[{"parameters":["exists"]}],
                    "enemy":[{"parameters":["exists"]}]
                },
                "Results": [ { "Type":"JumpToLabel", "arguments":["","br_choice"]} ] 
            },
            {   
                "option": "silent fail branch",
                "Results": [ { "Type":"JumpToLabel", "arguments":["","br_error"]} ] 
            }
        ]
    },
    {
        "$type": "Event+EventEntry+EventEntry_Question, Events",
        "label":"br_choice",
        "question":"$party.name$被敌人击败了",
        "options":[
            {   
                "option": "用大人的卡片让队员们撤离",
                "self_chara_conditions":[ { "parameters":["getStat","stats_derived_extended_mp","gte","1"] } ],
                "Results": [ { "Type":"ModStatEXValue", "arguments":["self","stats_derived_extended_mp","-1"]},
                            { "Type":"JumpToLabel", "arguments":["","br_escape"]} ] 
            },
            {   
                "option": "接受战败",  "isDefaultCancel":true,
                "Results": [ { "Type":"JumpToLabel", "arguments":["","br_defeat"]} ] 
            }
        ]
    },
    {
        "$type": "Event+EventEntry+EventEntry_Line, Events",
        "label": "br_escape",
        "line": "$party.name$成功逃离了敌人",
        "isLast": true
    },
    {
        "$type": "Event+EventEntry+EventEntry_Line, Events",
        "label": "br_defeat",
        "line": "失去战斗力的$party.name$被敌人俘获了",
        "isLast": true
    },
    {
        "$type": "Event+EventEntry+EventEntry_Line, Events",
        "label": "br_error",
        "line": "警告！由于内容缺失，该事件强制终止。",
        "isLast": true
    }
    ]
}
        ]
    },
    "Dictionary":
    {
        "Entries":
        {
            "zh-cn":
            {
"exp_event_combat_draw_ev01":"$party.name$的小队未能击败敌人",
