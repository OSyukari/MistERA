{
    "Events": {
        "list": [
            {                
                "ID": "exp_event_combat_draw",
                "events": [
                {
                    "$type": "Event+EventEntry+EventEntry_Branch, Events",
                    "options":[
                        {   
                            "target_chara_conditions":
                            {
                                "party":[{"parameters":["exists"]}]
                            },
                            "Results": [ { "Type":"JumpToLabel", "arguments":["","br_end"]} ] 
                        },
                        {   
                            "option": "silent fail branch",
                            "Results": [ { "Type":"JumpToLabel", "arguments":["","br_error"]} ] 
                        }
                    ]
                },
                {
                    "$type": "Event+EventEntry+EventEntry_Line, Events",
                    "label": "br_end",
                    "line": "exp_event_combat_draw_ev01",
                    "isLast": true
                },
                {
                    "$type": "Event+EventEntry+EventEntry_Line, Events",
                    "label": "br_error",
                    "line": "exp_event_combat_draw_ev99",
                    "isLast": true
                }
                            ]
                        },
            {                
                "ID": "exp_event_combat_victory",
                "events": [
                {
                    "$type": "Event+EventEntry+EventEntry_Branch, Events",
                    "options":[
                        {   
                            "target_chara_conditions":
                            {
                                "party":[{"parameters":["exists"]}],
                                "enemy":[{"parameters":["exists"]}]
                            },
                            "Results": [ { "Type":"JumpToLabel", "arguments":["","br_victory"]} ] 
                        },
                        {   
                            "option": "silent fail branch",
                            "Results": [ { "Type":"JumpToLabel", "arguments":["","br_error"]} ] 
                        }
                    ]
                },
                {
                    "$type": "Event+EventEntry+EventEntry_Line, Events",
                    "label": "br_victory",
                    "_comment":"change event flag if quest related, then open trade menu and allow looting on enemy or allow looting specific loots",
                    "line": "$party.name$击败了敌人"
                },
    {
        "$type": "Event+EventEntry+EventEntry_Question, Events",
        "question":"loot?",
        "options":[
            {   
                "self_chara_conditions":[ {"parameters":["exists"]}, {"parameters":["isPlayer"]} ],
                "option": "loot only",
                "Results": [ { "Type":"FactionExchangeInventory", "arguments":["party","enemy","false","true","true","false"]},
                                            { "Type":"JumpToLabel", "arguments":["","br_lootEnd"]} ] 
            },
            {   
                "self_chara_conditions":[ {"parameters":["exists"]}, {"parameters":["isPlayer"]} ],
                "option": "loot and capture", 
                "Results": [ { "Type":"FactionExchangeInventory", "arguments":["party","enemy","true","true","true","true"]},
                                            { "Type":"JumpToLabel", "arguments":["","br_lootEnd"]} ] 
            },
            {   
                "option": "do not loot",  "isDefaultCancel":true,
                "Results": [ { "Type":"JumpToLabel", "arguments":["","br_noLootEnd"]} ] 
            }
        ]
    },
                {
                    "$type": "Event+EventEntry+EventEntry_Line, Events",
                    "label": "br_lootEnd",
                    "_comment":"change event flag if quest related, then open trade menu and allow looting on enemy or allow looting specific loots",
                    "line": "$party.name$搜刮了战利品",
                    "isLast": true
                },
                {
                    "$type": "Event+EventEntry+EventEntry_Line, Events",
                    "label": "br_noLootEnd",
                    "_comment":"change event flag if quest related, then open trade menu and allow looting on enemy or allow looting specific loots",
                    "line": "$party.name$没有在此过多停留",
                    "isLast": true
                },
                {
                    "$type": "Event+EventEntry+EventEntry_Line, Events",
                    "label": "br_error",
                    "line": "警告！由于内容缺失，该事件强制终止。",
                    "isLast": true
                }
                ]
            },
            {                
                "ID": "exp_event_combat_defeat",
                "events": [
                {
                    "$type": "Event+EventEntry+EventEntry_Branch, Events",
                    "options":[
                        {   
                            "self_chara_conditions":[
                                {"parameters":["exists"]}, {"parameters":["isPlayer"]}
                            ],
                            "target_chara_conditions":
                            {
                                "party":[{"parameters":["exists"]}],
                                "enemy":[{"parameters":["exists"]}]
                            },
                            "Results": [ { "Type":"JumpToLabel", "arguments":["","br_choice"]} ] 
                        },
                        {   
                            "target_chara_conditions":
                            {
                                "party":[{"parameters":["exists"]}],
                                "enemy":[{"parameters":["exists"]}]
                            },
                            "Results": [ { "Type":"JumpToLabel", "arguments":["","br_defeat"]} ] 
                        },
                        {   
                            "option": "silent fail branch",
                            "Results": [ { "Type":"JumpToLabel", "arguments":["","br_error"]} ] 
                        }
                    ]
                },
                {
                    "$type": "Event+EventEntry+EventEntry_Question, Events",
                    "label":"br_choice",
                    "question":"$party.name$被敌人击败了",
                    "options":[
                        {   
                            "option": "用大人的卡片让队员们撤离（MP-1）",
                            "self_chara_conditions":[ { "parameters":["getStat","stats_derived_extended_mp","gte","1"] } ],
                            "Results": [ { "Type":"ModStatEXValue", "arguments":["self","stats_derived_extended_mp","-1"]},
                                        { "Type":"JumpToLabel", "arguments":["","br_escape"]} ] 
                        },
                        {   
                            "option": "接受战败（全员HP-1）",  "isDefaultCancel":true,
                            "Results": [ { "Type":"ModStatEXValue", "arguments":["party","stats_derived_extended_hp","-1"]},
                                         { "Type":"JumpToLabel", "arguments":["","br_defeat"]} ] 
                        }
                    ]
                },
                {
                    "$type": "Event+EventEntry+EventEntry_Line, Events",
                    "label": "br_escape",
                    "line": "$party.name$成功逃离了敌人",
                    "isLast": true
                },
                {
                    "$type": "Event+EventEntry+EventEntry_Line, Events",
                    "label": "br_defeat",
                    "line": "$party.name$尽力从敌人手下逃走，但都受了一定程度的伤",
                    "isLast": true
                },
                {
                    "$type": "Event+EventEntry+EventEntry_Line, Events",
                    "label": "br_error",
                    "line": "警告！由于内容缺失，该事件强制终止。",
                    "isLast": true
                }
                ]
            }
        ]
    },
    "Dictionary":
    {
        "Entries":
        {
            "zh-cn":
            {
"exp_event_combat_victory":"战斗胜利",
"exp_event_combat_draw":"战斗平局",
"exp_event_combat_defeat":"战斗失败",

"exp_event_combat_draw_ev01":"$party.name$的小队未能击败敌人",
"exp_event_combat_draw_ev99":"警告！由于内容缺失，该事件强制终止。"
            }
        }
    }
}