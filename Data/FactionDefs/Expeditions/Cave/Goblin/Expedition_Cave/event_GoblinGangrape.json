{
    "Events": {
        "list": [
            {
"ID": "event_goblin_gangRape",
"_comment": "this event can either branch into normal combat or players witness rape and leave.",
"events": [
{
    "$type": "Event+EventEntry+EventEntry_Branch, Events",
    "options":[
        {   
            "target_chara_conditions":
            {
                "party":[{"parameters":["exists"]}],
                "enemy":[{"parameters":["exists"]}],
                "victims":[{"parameters":["exists"]}]
            },
            "option": "active rape rescue mission",
            "Results": [    { "Type":"FullRecovery" , "arguments":["enemy"]},
                            { "Type":"JumpToLabel", "arguments":["","br_active_choice"]} ] 
        },
        {   
            "option": "silent fail branch",
            "Results": [ { "Type":"JumpToLabel", "arguments":["","br_error"]} ] 
        }
    ]
},
{
    "$type": "Event+EventEntry+EventEntry_Question, Events",
    "label":"br_active_choice",
    "portraitRefKey":"party", "portraitTagsOverride":["serious"],
    "question":"$party.name$发现一群肮脏矮小的哥布林正在轮奸被俘的女性\n敌方队伍的构成为：$enemy.nameCount$\n被俘对象为：$victims.name$",
    "options":[
        {   
            "option": "先准备一下",
            "tooltip": "该事件可以再次触发",
            "Results": [ { "Type":"JumpToLabel", "arguments":["","br_abort"]} ] 
        },
        {   
            "option": "继续潜伏",
            "Results": [ { "Type":"JumpToLabel", "arguments":["","br_event"]} ] 
        },
        {   
            "option": "准备战斗", 
            "target_chara_conditions":
            {
                "victims":[{"parameters":["CanTerminateExpedition"]}]
            },
            "tooltip":"请确保救援对象没有未结算的事件！",
            "Results": [ { "Type":"JumpToLabel", "arguments":["","br_combat_combat"]} ] 
        }
    ]
},
{
    "$type": "Event+EventEntry+EventEntry_Line, Events",
    "label": "br_event",
    "portraitRefKey":"party", "portraitTagsOverride":["serious"],
    "line": "$party.name$选择不惊动正在奸淫的哥布林们",
    "Results":[ { "Type":"ExecuteCallbackPermissive" , "arguments":["ResolveEvent"]} ],
    "isLast": true
},
{
    "$type": "Event+EventEntry+EventEntry_Line, Events",
    "label": "br_abort",
    "line": "$party.name$暂时撤退了",
    "Results":[ { "Type":"ExecuteCallbackPermissive" , "arguments":["RetryEvent"]} ],
    "isLast": true
},
{
    "$type": "Event+EventEntry+EventEntry_Line, Events",
    "label": "br_combat_combat",
    "portraitRefKey":"party", "portraitTagsOverride":["serious"],
    "line": "$party.name$偷袭了哥布林！（敌方全员HP-2）",
    "Results":[ { "Type":"ModStatEXValue" , "arguments":["enemy","stats_derived_extended_hp","-2"]},
                { "Type":"ExecuteCallbackPermissive" , "arguments":["ResolveEvent"]},
                { "Type":"StartCombat" , "arguments":["event_goblin_gangRape_rescue","exp_event_combat_Draw","event_goblin_combatDefeat"]} ],
    "isLast": true
},
{
    "$type": "Event+EventEntry+EventEntry_Line, Events",
    "label": "br_error",
    "line": "警告！由于内容缺失，该事件强制终止。",
    "Results":[ { "Type":"ExecuteCallbackPermissive" , "arguments":["ResolveEvent"]} ],
    "isLast": true
}
                ]
            },



            {
                "ID": "event_goblin_gangRape_rescue",
                "events": [
                {
                    "$type": "Event+EventEntry+EventEntry_Branch, Events",
                    "options":[
                        {   
                            "target_chara_conditions":
                            {
                                "party":[{"parameters":["exists"]}], "enemy":[{"parameters":["exists"]}]
                            },
                            "Results": [ { "Type":"JumpToLabel", "arguments":["","br_hasenemy"]} ] 
                        },
                        {   
                            "option": "silent fail branch",
                            "Results": [ { "Type":"JumpToLabel", "arguments":["","br_noenemy"]} ] 
                        }
                    ]
                },
                {
                    "$type": "Event+EventEntry+EventEntry_Line, Events",
                    "label": "br_hasenemy",
                    "portraitRefKey":"party", "portraitTagsOverride":["serious"],
                    "line": "$party.name$击败了哥布林，然后……"
                },
                {
                    "$type": "Event+EventEntry+EventEntry_Branch, Events",
                    "label": "br_noenemy",
                    "options":[
                        {   
                            "target_chara_conditions":
                            {
                                "party":[{"parameters":["exists"]}], "victims":[{"parameters":["exists"]}]
                            },
                            "option": "no enemy, rescue only",
                            "Results": [ { "Type":"JumpToLabel", "arguments":["","br_victims"]} ] 
                        },
                        {   
                            "option": "silent fail branch",
                            "Results": [ { "Type":"JumpToLabel", "arguments":["","br_error"]} ] 
                        }
                    ]
                },
                {
                    "$type": "Event+EventEntry+EventEntry_Question, Events",
                    "label":"br_victims",
                    "portraitRefKey":"party", "portraitTagsOverride":["serious"],
                    "question":"$party.name$发现了被哥布林们残酷对待后奄奄一息的$victims.name$",
                    "options":[
                        {     
                            "target_chara_conditions":
                            {
                                "victims":[{"parameters":["CanTerminateExpedition"]}]
                            },
                            "option": "搜刮战利品",
                            "tooltip":"请确保救援对象没有未结算的事件！",
                            "Results": [    { "Type":"TerminateExpedition", "arguments":["victims"]},
                                            { "Type":"FactionExchangeInventory", "arguments":["party","victims","true","true","true","true","event_goblin_gangRape_rescuedChara"]},
                                            { "Type":"JumpToLabel", "arguments":["","br_lootEnd"]} ] 
                        },
                        {   
                            "option": "什么都不拿",   "isDefaultCancel":true,
                            "Results": [ { "Type":"JumpToLabel", "arguments":["","br_noLootEnd"]} ] 
                        }
                    ]
                },
                {
                    "$type": "Event+EventEntry+EventEntry_Line, Events",
                    "label": "br_lootEnd",
                    "portraitRefKey":"party",
                    "line": "$party.name$搜刮完之后离开了这里",
                    "Results":[ { "Type":"ExecuteCallbackPermissive" , "arguments":["ResolveEvent"]} ],
                    "isLast": true
                },
                {
                    "$type": "Event+EventEntry+EventEntry_Line, Events",
                    "label": "br_noLootEnd",
                    "portraitRefKey":"party",
                    "_comment":"change event flag if quest related, then open trade menu and allow looting on enemy or allow looting specific loots",
                    "line": "$party.name$没有在此过多停留",
                    "isLast": true
                },
                {
                    "$type": "Event+EventEntry+EventEntry_Line, Events",
                    "label": "br_error",
                    "line": "警告！由于内容缺失，该事件强制终止。",
                    "Results":[ { "Type":"ExecuteCallbackPermissive" , "arguments":["ResolveEvent"]} ],
                    "isLast": true
                }

                ]
            },
            {
                "ID": "event_goblin_gangRape_rescuedChara",
                "events": [
                {
                    "$type": "Event+EventEntry+EventEntry_Branch, Events",
                    "options":[
                        {   
                            "target_chara_conditions":
                            {
                                "party":[{"parameters":["exists"]}], "rescued":[{"parameters":["exists"]}]
                            },
                            "Results": [ { "Type":"JumpToLabel", "arguments":["","br_hasRescue"]} ] 
                        },
                        {   
                            "option": "silent fail branch",
                            "Results": [ { "Type":"JumpToLabel", "arguments":["","br_error"]} ] 
                        }
                    ]
                },
                {
                    "$type": "Event+EventEntry+EventEntry_Line, Events",
                    "label": "br_hasRescue",
                    "portraitRefKey":"party", "portraitTagsOverride":["serious"],
                    "line": "$party.name$营救了被哥布林们残酷对待的受害者"
                },
                {
                    "$type": "Event+EventEntry+EventEntry_Line, Events",
                    "line": "……从救出的$rescued.name$那获得了更多此处的情报",
                    "Results":[ { "Type":"ExecuteCallbackPermissive" , "arguments":["ResolveEvent"]} ],
                    "isLast": true
                },
                {
                    "$type": "Event+EventEntry+EventEntry_Line, Events",
                    "label": "br_error",
                    "line": "警告！由于内容缺失，该事件强制终止。",
                    "Results":[ { "Type":"ExecuteCallbackPermissive" , "arguments":["ResolveEvent"]} ],
                    "isLast": true
                }

                ]
            }
        ]
    },
    "Dictionary": {
        "Entries": {
            "zh-cn": {
                "event_goblin_gangRape":"哥布林的凌辱",
                "event_goblin_gangRape_rescue":"哥布林的囚犯"
            }
        }
    }
}