            "zh-cn": {
                "exp_event_cave_goblinOutpost": "发现哥布林哨站",
                "exp_event_cave_goblinOutpost_ongoing": "$names$在洞穴深处发现了一个由粗糙木头和兽皮搭建的哥布林前哨站，几只绿皮生物正在篝火旁打盹。",
                "exp_event_cave_goblinOutpost_result_stealthSuccess": "$names$屏住呼吸，小心翼翼地从阴影中潜行，成功绕过了哥布林哨站。",
                "exp_event_cave_goblinOutpost_result_stealthFail_captured": "$names$在潜行时不慎碰倒了石子，惊醒的哥布林们一拥而上！她们被粗暴地剥光衣服，手脚被缚，沦为哥布林们轮流发泄兽欲的公共肉便器。",
                "exp_event_cave_goblinOutpost_result_distractionSuccess": "$names$向远处投掷石块制造声响，成功将哥布林的注意力引开，趁机安全地通过了该区域。",
                "exp_event_cave_goblinOutpost_result_distractionAttractsOther": "$names$制造的混乱不仅惊动了哥布林，还从洞穴更深处引来了一只巨大的洞穴蠕虫。蠕虫吞噬了受惊的哥布林，然后用它黏滑的、布满吸盘的身体将$names$包裹起来，进行了一场漫长而窒息的体内侵犯。",
                "exp_event_cave_goblinOutpost_result_findTreasure": "$names$大胆地潜入哨站，在一个被遗忘的角落里发现了一个破旧的箱子，里面装有一些有用的道具。",

                "exp_event_cave_goblinOutpost_result_findTreasure1":"队伍试图悄悄通过哥布林的哨站，但一名成员不慎发出了声响，导致警报大作。"
            }
        }
    }
