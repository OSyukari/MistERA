{
    "Events": {
        "list": [
            {
                "ID": "event_caveGoblinEncounter",
                "TargetValidators":
                [
                    {
                        "refkeys":["decoy"], "baseScope":"ScopeWithinRef", "extraScopeArguments":["party"],
                        "minTargetCount":1, "maxTargetCount":1,
                        "pickAmongValidTargets":true, "mustHaveMoreValidTargets":true,
                        "allowEventOnMinTargetCountMiss":true
                    }
                ],
"events": [
{
    "$type": "Event+EventEntry+EventEntry_Branch, Assembly-CSharp",
    "options":[
        {   
            "target_chara_conditions":
            {
                "party":[{"parameters":["exists"]}],
                "enemy":[{"parameters":["exists"]}]
            },
            "option": "player branch show option",
            "Results": [    { "Type":"FullRecovery" , "arguments":["enemy"]},
                            { "Type":"JumpToLabel", "arguments":["","br_choice"]} ] 
        },
        {   
            "option": "silent fail branch",
            "Results": [ { "Type":"JumpToLabel", "arguments":["","br_error"]} ] 
        }
    ]
},
{
    "$type": "Event+EventEntry+EventEntry_Question, Assembly-CSharp",
    "label":"br_choice",
                    "portraitRefKey":"party", "portraitTagsOverride":["serious"],
    "question":"$party.name$在洞穴中遇到了哥布林巡逻队，冲突已无法避免\n敌方队伍的构成为：$enemy.nameCount$",
    "options":[
        {   
            "target_chara_conditions":
            {
                "target":[{"parameters":["exists"]}]
            },
            "option": "让$decoy.name$断后，其他人撤离",
            "Results": [ { "Type":"JumpToLabel", "arguments":["","br_escape"]} ] 
        },
        {   
            "option": "准备战斗", 
            "Results": [ { "Type":"JumpToLabel", "arguments":["","br_combat"]} ] 
        }
    ]
},
{
    "$type": "Event+EventEntry+EventEntry_Branch, Assembly-CSharp",
    "label":"br_combat",
    "options":[
        {   
            "conditions":[{"randChance":0.2}],
            "option": "random chance scare goblins away",
            "Results": [ { "Type":"JumpToLabel", "arguments":["","br_combat_scare"]} ] 
        },
        {   
            "_comment":"fight",
            "option": "combat",
            "Results": [ { "Type":"JumpToLabel", "arguments":["","br_combat_combat"]} ] 
        }
    ]
},
{
    "$type": "Event+EventEntry+EventEntry_Question, Assembly-CSharp",
    "label":"br_combat_scare",
                    "portraitRefKey":"party", "portraitTagsOverride":["serious"],
    "question":"$party.name$的迎战姿态吓唬住了哥布林，哥布林开始四处逃窜！",
    "options":[
        {   
            "option": "追杀",
            "tooltip": "敌方全员HP-2，然后开始战斗",
            "Results": [ { "Type":"JumpToLabel", "arguments":["","br_combat_scare_chase"]} ] 
        },
        {   
            "option": "放弃", 
            "Results": [ { "Type":"JumpToLabel", "arguments":["","br_combat_scare_end"]} ] 
        }
    ]
},
{
    "$type": "Event+EventEntry+EventEntry_Line, Assembly-CSharp",
    "label": "br_combat_scare_end",
                    "portraitRefKey":"party", "portraitTagsOverride":["serious"],
    "line": "$party.name$吓跑了哥布林巡逻队",
    "Results":[ { "Type":"ExecuteCallbackPermissive" , "arguments":["ResolveEvent"]} ],
    "isLast": true
},
{
    "$type": "Event+EventEntry+EventEntry_Line, Assembly-CSharp",
    "label": "br_combat_scare_chase",
                    "portraitRefKey":"party", "portraitTagsOverride":["serious"],
    "line": "$party.name$追击四处逃窜的哥布林们",
    "Results":[ { "Type":"ModStatEXValue" , "arguments":["enemy","stats_derived_extended_hp","-2"]},
                { "Type":"ExecuteCallbackPermissive" , "arguments":["ResolveEvent"]} ],
    "nextEntryLabel":"br_combat_start"
},
{
    "$type": "Event+EventEntry+EventEntry_Branch, Assembly-CSharp",
    "label": "br_combat_ambush_validator",
    "options":[
        {   
            "target_chara_conditions":
            {
                "party":[{"parameters":["exists"]}],
                "enemy":[{"parameters":["exists"]}]
            },
            "option": "player branch show option",
            "Results": [    { "Type":"FullRecovery" , "arguments":["enemy"]},
                            { "Type":"JumpToLabel", "arguments":["","br_combat_ambush"]} ] 
        },
        {   
            "option": "silent fail branch",
            "Results": [ { "Type":"JumpToLabel", "arguments":["","br_error"]} ] 
        }
    ]
},
{
    "$type": "Event+EventEntry+EventEntry_Line, Assembly-CSharp",
    "label": "br_combat_ambush",
                    "portraitRefKey":"party", "portraitTagsOverride":["serious"],
    "line": "$party.name$偷袭了哥布林！（敌方全员HP-1）",
    "Results":[ { "Type":"ModStatEXValue" , "arguments":["enemy","stats_derived_extended_hp","-1"]},
                { "Type":"ExecuteCallbackPermissive" , "arguments":["ResolveEvent"]} ],
    "nextEntryLabel":"br_combat_start"
},
{
    "$type": "Event+EventEntry+EventEntry_Line, Assembly-CSharp",
    "label": "br_combat_combat",
                    "portraitRefKey":"party", "portraitTagsOverride":["serious"],
    "line": "$party.name$与哥布林们展开战斗！",
    "Results":[ { "Type":"ExecuteCallbackPermissive" , "arguments":["ResolveEvent"]} ],
    "nextEntryLabel":"br_combat_start"
},
{
    "$type": "Event+EventEntry+EventEntry_Branch, Assembly-CSharp",
    "label": "br_combat_combat_validator",
    "options":[
        {   
            "target_chara_conditions":
            {
                "party":[{"parameters":["exists"]}],
                "enemy":[{"parameters":["exists"]}]
            },
            "option": "player branch show option",
            "Results": [ { "Type":"JumpToLabel", "arguments":["","br_combat_combat"]} ] 
        },
        {   
            "option": "silent fail branch",
            "Results": [ { "Type":"JumpToLabel", "arguments":["","br_error"]} ] 
        }
    ]
},
{
    "$type": "Event+EventEntry+EventEntry_Branch, Assembly-CSharp",
    "label": "br_combat_start",
    "isLast": true,
    "options":[
    {   
        "option": "silent branch event, this shouldnt be displayed",
        "Results": [ 
            { "Type":"StartCombat" , "arguments":["exp_event_combat_Victory","exp_event_combat_Draw","event_goblin_combatDefeat"]} ] 
    }
    ]
},
{
    "$type": "Event+EventEntry+EventEntry_Line, Assembly-CSharp",
    "label": "br_error",
    "line": "警告！由于内容缺失，该事件强制终止。",
    "Results":[ { "Type":"ExecuteCallbackPermissive" , "arguments":["ResolveEvent"]} ],
    "isLast": true
}
                ]
            }
        ]
    },
    "Dictionary": {
        "Entries": {
            "zh-cn": {
"event_caveGoblinEncounter":"哥布林遭遇"
            }
        }
    }
}