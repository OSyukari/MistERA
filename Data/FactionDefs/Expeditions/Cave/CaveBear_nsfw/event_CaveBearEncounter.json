{
    "Events": {
        "list": [
            {
                "ID": "event_caveBearEncounter",
"TargetValidators":
[
    {
        "refkeys":["trainer"],
        "baseScope":"ScopeWithinRef",
        "extraScopeArguments":["party"],
        "minTargetCount":1,
        "maxTargetCount":1,
        "pickAmongValidTargets":true,
        "allowEventOnMinTargetCountMiss":true
    }
],
                "events": [
{
    "$type": "Event+EventEntry+EventEntry_Branch, Events",
    "options":[
        {   
            "target_chara_conditions":
            {
                "party":[{"parameters":["exists"]}],
                "enemy":[{"parameters":["exists"]}]
            },
            "option": "player branch show option",
            "Results": [ { "Type":"JumpToLabel", "arguments":["","br_choice"]} ] 
        },
        {   
            "option": "silent fail branch",
            "Results": [ { "Type":"JumpToLabel", "arguments":["","br_error"]} ] 
        }
    ]
},
{
    "$type": "Event+EventEntry+EventEntry_Question, Events",
    "label":"br_choice",
    "question":"$party.name$在洞穴深处遭遇了一头巨大的穴熊",
    "options":[
        {   
            "target_chara_conditions":
            {
                "trainer":[{"parameters":["exists"]}]
            },
            "_comment":"scope a trainer chara",
            "option": "让$trainer.name$尝试安抚野兽",
            "Results": [ { "Type":"JumpToLabel", "arguments":["","br_appease"]} ] 
        },
        {   
            "option": "准备战斗，驱赶野兽。", 
            "Results": [ { "Type":"JumpToLabel", "arguments":["","br_combat"]} ] 
        }
    ]
},
{
    "$type": "Event+EventEntry+EventEntry_Branch, Events",
    "label":"br_appease",
    "options":[
        {   
            "conditions":[{"randChance":0}],
            "option": "branch_appease_success",
            "Results": [ { "Type":"JumpToLabel", "arguments":["","br_appease_success"]} ] 
        },
        {   
            "target_chara_conditions":
            {
                "trainer":[{"parameters":["isFemale"]}]
            },
            "option": "silent fail branch",
            "Results": [ { "Type":"JumpToLabel", "arguments":["","br_appease_fail_female"]} ] 
        },
        {   
            "option": "branch_appease_fail",
            "Results": [ { "Type":"JumpToLabel", "arguments":["","br_appease_fail"]} ] 
        }
    ]
},
{
    "$type": "Event+EventEntry+EventEntry_Branch, Events",
    "label":"br_combat",
    "options":[
        {   
            "conditions":[{"randChance":0.5}],
            "option": "random chance scare beast away",
            "Results": [ { "Type":"JumpToLabel", "arguments":["","br_combat_scare"]} ] 
        },
        {   
            "_comment":"fight",
            "option": "combat",
            "Results": [ { "Type":"JumpToLabel", "arguments":["","br_combat_combat"]} ] 
        }
    ]
},
{
    "$type": "Event+EventEntry+EventEntry_Line, Events",
    "label": "br_combat_scare",
    "line": "$party.name$的迎战姿态吓唬住了野兽，避免了冲突",
    "Results":[ { "Type":"ExecuteCallbackPermissive" , "arguments":["ResolveEvent"]} ],
    "isLast": true
},
{
    "$type": "Event+EventEntry+EventEntry_Line, Events",
    "label": "br_combat_combat",
    "line": "$party.name$与暴怒的穴熊展开战斗！",
    "Results":[ { "Type":"ExecuteCallbackPermissive" , "arguments":["ResolveEvent"]} ],
    "nextEntryLabel":"br_combat_start"
},
{
    "$type": "Event+EventEntry+EventEntry_Branch, Events",
    "label": "br_combat_start",
    "isLast": true,
    "options":[
    {   
        "option": "silent branch event, this shouldnt be displayed",
        "Results": [ 
            { "Type":"FullRecovery" , "arguments":["enemy"]},
            { "Type":"StartCombat" , "arguments":["exp_event_combat_victory","exp_event_combat_draw","exp_event_combat_defeat"]} ] 
    }
    ]
},
{
    "$type": "Event+EventEntry+EventEntry_Line, Events",
    "label": "br_appease_fail",
    "line": "$trainer.name$的安抚尝试反而激怒了野兽！",
    "nextEntryLabel": "br_combat_combat"
},
{
    "$type": "Event+EventEntry+EventEntry_Line, Events",
    "label": "br_appease_success",
    "line": "$trainer.name$成功安抚了狂躁的野兽。",
    "Results":[ { "Type":"ExecuteCallbackPermissive" , "arguments":["ResolveEvent"]} ],
    "isLast": true
},
{
    "$type": "Event+EventEntry+EventEntry_Line, Events",
    "label": "br_error",
    "line": "警告！由于内容缺失，该事件强制终止。",
    "Results":[ { "Type":"ExecuteCallbackPermissive" , "arguments":["ResolveEvent"]} ],
    "isLast": true
},
{
    "$type": "Event+EventEntry+EventEntry_Line, Events",
    "label": "br_appease_fail_female",
    "line": "$trainer.name$的安抚尝试失败了！"
},
{
    "$type": "Event+EventEntry+EventEntry_Line, Events",
    "line": "被激怒的野兽将$trainer.name$扑倒，将她当成了发泄欲望的对象。",
    "Results":[ { "Type":"ExecuteCallbackPermissive" , "arguments":["ResolveEvent"]} ]
},
{
    "$type": "Event+EventEntry+EventEntry_Branch, Events",
    "options":[
        {   
            "option": "silent branch event, this shouldnt be displayed",
            "Results": [ 
            { "Type":"FullRecovery" , "arguments":["enemy"]},
            { "Type":"StartSexJobInParty" , "arguments":["enemy","trainer","trainer","120","","","","event_caveBearEncounter_ev09_text"]},
                         {"Type":"EventEnd"}] 
        }
    ]
}
                ]
            }
        ]
    },
    "Dictionary": {
        "Entries": {
            "zh-cn": {
                "event_caveBearEncounter": "穴熊遭遇",
                "event_caveBearEncounter_ev09_text": "$names$被穴熊强奸"
            }
        }
    }
}