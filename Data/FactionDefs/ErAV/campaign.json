            "en-us": {
                "campaign_erav": "ErAV: Repayment",
                "campaign_erav_tooltip": "Your parents died in an accident, leaving a crushing joint-guarantor debt. Under yakuza princess Kiryu Kanon's ultimatum, you must repay it before graduation — take over the AV agency, or find your own way out.",
                "campaign_erav_start": "Begin",
                "campaign_erav_start_tooltip": "Start as the customizable protagonist (family name forced to 'Miyama')",
