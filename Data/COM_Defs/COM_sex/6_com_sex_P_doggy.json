                "com_sex_P_doggy":"%%tooltip_sex_com_alternating_tooltip%%",

                "com_sex_P_doggy_displayName_1": "еҗҺиғҢдҪҚV",
                "com_sex_P_doggy_displayName_2": "дәӨжӣҝеҗҺиғҢдҪҚV",
                "com_sex_P_doggy_displayName_3": "иҪ®жөҒеҗҺиғҢдҪҚV",
                "com_sex_P_doggy_displayName_4": "еҗҢж—¶еҗҺиғҢдҪҚV",

                "com_sex_P_doggy_description_begin_1_1":"$doer.firstname$еңЁе“Ғе‘іиә«дҪ“еҠЁеј№дёҚеҫ—зҡ„$receiver.firstname$иҶЈеҶ…зҡ„и§Ұж„ҹзҡ„еҗҢж—¶гҖҒеҶҚж¬Ўй–Ӣе§ӢеҠЁиө·дәҶи…°вҖҰ",
                "com_sex_P_doggy_description_begin_1_2":"$doer.firstname$е°ҶжҷӮеҒңдёӯзҡ„$receiver.firstname$д»°йқўжҺЁеҖ’гҖҒжҠҠеҚіе°Ҷжҡҙзҷәзҡ„йҳҙиҢҺжҸ’е…ҘдәҶ$receiver.v$йҮҢвҖҰ",

                "com_sex_P_doggy_description_begin_2_1":"$doer.firstname$еңЁе“Ғе‘ізқҖзқЎзң дёӯзҡ„$receiver.firstname$иҶЈеҶ…зҡ„и§Ұж„ҹзҡ„еҗҢж—¶гҖҒеҶҚж¬Ўй–Ӣе§ӢеҠЁиө·дәҶи…°вҖҰ",
                "com_sex_P_doggy_description_begin_2_2":"$doer.firstname$е°ҶзқЎзң дёӯзҡ„$receiver.firstname$д»°йқўжҺЁеҖ’гҖҒжҠҠеҚіе°Ҷжҡҙзҷәзҡ„йҳҙиҢҺжҸ’е…ҘдәҶ$receiver.v$йҮҢвҖҰ",

                "com_sex_P_doggy_description_begin_3_1":"$master.firstname$е‘Ҫд»Ө$doer.firstname$ж”№еҸҳдҪ“дҪҚжҲҗеҫҢиғҢдҪҚпјҢеҶҚж¬Ўз§»еҠЁи…°йғЁгҖӮ\n$doer.firstname$жҠҠ$receiver.firstname$жҺЁеҖ’пјҢд»ҺеҗҺйқўеҺӢдҪҸпјҢеҶҚж¬ЎејҖе§ӢжүӯеҠЁи…°вҖҰ",
                "com_sex_P_doggy_description_begin_3_2":"$receiver.firstname$иҮӘе·ұеҗ‘еүҚеҖ’дёӢпјҢеҢҚеҢҗеңЁең°дёҠпјҢи®©$doer.firstname$з”ЁеҗҺиғҢдҪҚжүӯеҠЁи…°вҖҰ",
                "com_sex_P_doggy_description_begin_3_3":"$doer.firstname$жҠҠ$receiver.firstname$жҺЁеҖ’пјҢд»ҺеҗҺйқўеҺӢдҪҸпјҢз„¶еҗҺд»ҘеҗҺиғҢдҪҚзҡ„е§ҝеҠҝеҶҚж¬ЎејҖе§ӢжүӯеҠЁи…°вҖҰ",
                "com_sex_P_doggy_description_begin_3_4":"$master.firstname$е‘Ҫд»Ө$doer.firstname$ж”№еҸҳдҪ“дҪҚжҲҗеҫҢиғҢдҪҚпјҢеҶҚж¬Ўз§»еҠЁи…°йғЁгҖӮ\n$doer.firstname$жҠҪжҸ’зқҖ$receiver.firstname$еҢҚеҢҗзҡ„иә«дҪ“пјҢеҶҚж¬ЎејҖе§ӢжүӯеҠЁи…°вҖҰ",
                "com_sex_P_doggy_description_begin_3_5":"$receiver.firstname$жүӯиҪ¬иә«дҪ“иҮӘе·ұеҢҚеҢҗеңЁең°пјҢи®©$doer.firstname$еңЁеҗҺйқўжүӯеҠЁзқҖи…°вҖҰ",
