            "zh-cn":
            {
                "com_sex_P_doggy":"%%tooltip_sex_com_alternating_tooltip%%",

                "com_sex_P_doggy_displayName_1": "后背位V",
                "com_sex_P_doggy_displayName_2": "交替后背位V",
                "com_sex_P_doggy_displayName_3": "轮流后背位V",
                "com_sex_P_doggy_displayName_4": "同时后背位V",

                "com_sex_P_doggy_description_begin_1_1":"$doer.firstname$在品味身体动弹不得的$receiver.firstname$膣内的触感的同时、再次開始动起了腰…",
                "com_sex_P_doggy_description_begin_1_2":"$doer.firstname$将時停中的$receiver.firstname$仰面推倒、把即将暴発的阴茎插入了$receiver.v$里…",

                "com_sex_P_doggy_description_begin_2_1":"$doer.firstname$在品味着睡眠中的$receiver.firstname$膣内的触感的同时、再次開始动起了腰…",
                "com_sex_P_doggy_description_begin_2_2":"$doer.firstname$将睡眠中的$receiver.firstname$仰面推倒、把即将暴発的阴茎插入了$receiver.v$里…",

                "com_sex_P_doggy_description_begin_3_1":"$master.firstname$命令$doer.firstname$改变体位成後背位，再次移动腰部。\n$doer.firstname$把$receiver.firstname$推倒，从后面压住，再次开始扭动腰…",
                "com_sex_P_doggy_description_begin_3_2":"$receiver.firstname$自己向前倒下，匍匐在地上，让$doer.firstname$用后背位扭动腰…",
                "com_sex_P_doggy_description_begin_3_3":"$doer.firstname$把$receiver.firstname$推倒，从后面压住，然后以后背位的姿势再次开始扭动腰…",
                "com_sex_P_doggy_description_begin_3_4":"$master.firstname$命令$doer.firstname$改变体位成後背位，再次移动腰部。\n$doer.firstname$抽插着$receiver.firstname$匍匐的身体，再次开始扭动腰…",
                "com_sex_P_doggy_description_begin_3_5":"$receiver.firstname$扭转身体自己匍匐在地，让$doer.firstname$在后面扭动着腰…",
                "com_sex_P_doggy_description_begin_3_6":"$doer.firstname$在插入的状态下将$receiver.firstname$的身体转回去，趴在地上，以后背位的姿势再次开始扭动腰…",
                "com_sex_P_doggy_description_begin_3_7":"$master.firstname$命令$doer.firstname$用後背位侵犯$receiver.firstname$\n$doer.firstname$让$receiver.firstname$匍匐，把肉棒插入$receiver.firstname$的$receiver.v$摇晃腰…",
                "com_sex_P_doggy_description_begin_3_8":"$receiver.firstname$将%STR_BODY(\"尻：外見\", MTAR:0)%对向$doer.firstname$，从后面让肉棒插入$receiver.v$…",
                "com_sex_P_doggy_description_begin_3_9":"$doer.firstname$的肉棒从后面插入$receiver.firstname$的$receiver.v$，开始多次撞击腰部",

                "com_sex_P_doggy_description_begin_4_1":"$receiver.firstname$被情欲所驱使，像是在撒娇一样伸出屁股…",
                "com_sex_P_doggy_description_begin_4_2":"发情的$receiver.firstname$在粗暴的抽插下喘着粗气……",


                "com_sex_P_doggy_description_after_1":"在射精的瞬間$doer.firstname$将阴茎深深突入了膣内最深处…",
                "com_sex_P_doggy_description_after_2_1":"$receiver.firstname$撑不起来的上身，全身颤抖着…",
                "com_sex_P_doggy_description_after_2_2":"$receiver.firstname$一边品尝着激烈绝顶的余韵，一边淫荡地扭动着含着$doer.firstname$的屁股…",
                

                "com_sex_P_doggy_description_remove_1":"$doer.firstname$从$receiver.firstname$的小穴内拔出了阴茎…",

                "com_sex_P_doggy_description_ongoing_1":"$receiver.firstname$的小穴插入了$doer.firstname$的阴茎…",
                "com_sex_P_doggy_description_ongoing_2_1":"$doer.firstname$从背后激烈地抽插着昏过去的$receiver.firstname$的小穴…",
                "com_sex_P_doggy_description_ongoing_2_2":"$doer.firstname$从后面无数次摇动腰部拍打在筋疲力尽的$receiver.firstname$的$receiver.v$上…",

                "com_sex_P_doggy_description_ongoing_3_1":"$master.firstname$命令$doer.firstname$用后背位插入$receiver.firstname$，并更激烈地扭动腰",
                "com_sex_P_doggy_description_ongoing_3_2_1":"$doer.firstname$按照指示的那样激烈地运动腰部，从后面无数次地冲击着$receiver.firstname$的小穴深处…",
