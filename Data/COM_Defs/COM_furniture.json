    "Dictionary":
    {
        "Entries":
        {
            "zh-cn":
            {
                "com_furniture_sleep_displayName_1": "睡觉",
                "com_furniture_sleep_displayName_2": "一起睡觉",
                "com_furniture_sleep": "睡觉。玩家只有在可睡眠时间段（默认为23H-6H）才可睡眠，可以在阵营管理-工作分配界面检查玩家的时间表确认。\n\n该指令执行后，参与者会获得时长等于参与者自身%%stats_derived_sleepNeed%%分钟的睡眠状态。当该状态结束时角色会立刻醒来\n",
                "com_furniture_sleep_begin_1": "$doer.firstname$舒服地把自己埋进被子里",
                "com_furniture_sleep_begin_2": "$doer.firstname$关掉床头灯后缓缓闭上眼睛",
                "com_furniture_sleep_after_1": "$doer.firstname$睡着了",

                "com_furniture_takingBreak_displayName_1": "休息",
                "com_furniture_takingBreak_displayName_2": "一起休息",
                "com_furniture_takingLongBreak_displayName_1": "长休",
                "com_furniture_takingLongBreak_displayName_2": "一起长休",
                "com_furniture_takingBreak_begin_1": "$doer.firstname$伸了个懒腰，开始放松休息",
                "com_furniture_takingBreak_begin_2": "$doer.firstname$享受着片刻的安静",
                
                "com_furniture_playVideoGames_displayName_1": "打游戏",
                "com_furniture_playVideoGames_displayName_2": "一起打游戏",
                "com_furniture_playVideoGames_displayName_3": "打游戏",
                "com_furniture_playVideoGames_begin_1": "$doer.firstname$拿起手柄，沉浸在了游戏里。",
                "com_furniture_playVideoGames_begin_2": "$doer.firstname$盯着游戏画面，眼神专注",
                
                "com_furniture_watchVideo_displayName_1": "看影片",
                "com_furniture_watchVideo_displayName_2": "一起看影片",
                "com_furniture_watchVideo_displayName_3": "看影片",
                "com_furniture_watchVideo_begin_1": "$doer.firstname$拿起遥控器，打开电视，开始观看自己喜欢的节目。",
                "com_furniture_watchVideo_begin_2": "$doer.firstname$窝在沙发里，盖上毯子，舒服地看起了电视。",
                "com_furniture_watchVideo_begin_3": "$doer.firstname$调整好姿势，眼睛一眨不眨地盯着电视屏幕，完全被剧情吸引住了。",
                
                "com_furniture_takeShower_displayName_1": "洗澡",
                "com_furniture_takeShower_displayName_2": "一起洗澡",
                "com_furniture_takeShower_displayName_3": "全员一起洗澡",
                "com_furniture_takeShower_begin_1": "$doer.firstname$走进浴室，打开花洒，让温暖的水流冲刷着全身。",
                "com_furniture_takeShower_begin_2": "$doer.firstname$关上浴室门，水声哗哗响起，开始享受沐浴的放松时刻。",
                "com_furniture_takeShower_begin_3": "$doer.firstname$走进浴室，蒸汽氤氲，准备洗去一天的疲惫。",

                "com_furniture_cryosleep_displayName_REMOVE": "解除休眠",
                "com_furniture_cryosleep_displayName_ADD": "冷冻休眠",
                "com_furniture_cryosleep_displayName": "冷冻休眠",
                "com_furniture_cryosleep": "冷冻休眠",
                "com_furniture_cryosleep_begin_1_ADD": "$doer.firstname$将$receiver.firstname$安置在冷冻休眠装置中",
                "com_furniture_cryosleep_after_1_ADD": "$receiver.firstname$陷入了冷冻休眠中",
                "com_furniture_cryosleep_begin_1_REMOVE": "$doer.firstname$开始解除$receiver.firstname$的冷冻休眠",
                "com_furniture_cryosleep_after_1_REMOVE": "$receiver.firstname$从冷冻休眠中醒来了",

                "com_furniture_prison_displayname": "监禁",
                "com_furniture_prison_displayname_ADD": "监禁对象",
                "com_furniture_prison_displayname_REMOVE": "移出监牢",
                "com_furniture_prison_begin_1_ADD": "$doer.firstname$将$receiver.firstname$关押在监牢中",
                "com_furniture_prison_after_1_ADD": "$receiver.firstname$被关押了起来",
                "com_furniture_prison_begin_1_REMOVE": "$doer.firstname$尝试从监牢将$receiver.firstname$释放",
                "com_furniture_prison_after_1_REMOVE": "$receiver.firstname$被释放了",
                
