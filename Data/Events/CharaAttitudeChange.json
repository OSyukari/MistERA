{
    "Events": {
        "list": [
    {
        "ID": "AttitudeChange",
        "_comment":"triggers on character attitude change.",
        "SelfValidator":{
            "chara_conditions":[
                {"parameters":["exists"]},
                {"parameters":["excludePlayer"]},
                {"parameters":["isConscious"]}
            ]
        },
        "events": [
            {
                "$type": "Event+EventEntry+EventEntry_Branch, Assembly-CSharp",
                "options":[
                    {   
                        "Results": [ { "Type":"CheckRelationship", "arguments":["self","target"]} ] 
                    }
                ],
                "isLast": true
            }
        ]
    },
    {
        "ID": "RequestRelationshipChange",
        "_comment":"triggers on character attitude change.",
        "SelfValidator":{
            "chara_conditions":[
                {"parameters":["exists"]},
                {"parameters":["excludePlayer"]},
                {"parameters":["isConscious"]}
            ]
        },
        "events": [
            {
                "$type": "Event+EventEntry+EventEntry_Branch, Assembly-CSharp",
                "options":[
                    {   
                        "target_chara_conditions":{
                            "target":[
                                {"parameters":["exists"]},
                                {"parameters":["isPlayer"]},
                                {"parameters":["isConscious"]}
                            ]
                        },
                        "option": "player branch",
                        "Results": [ { "Type":"GetKojoEntryFromAppendStrings", "arguments":["self", "target","targetRel","kojotext"] },
                                     { "Type":"JumpToLabel", "arguments":["","br_choice"]} ] 
                    },
                    {   
                        "target_chara_conditions":{
                            "target":[
                                {"parameters":["exists"]},
                                {"parameters":["excludePlayer"]},
                                {"parameters":["isConscious"]}
                            ]
                        },
                        "option": "npc branch",
                        "Results": [ { "Type":"ExecuteCallbackPermissive", "arguments":["acceptanceCheck"] },
                                     { "Type":"EventEnd" } ] 
                    },
                    {   
                        "Results": [ { "Type":"EventEnd" } ] 
                    }
                ]
            },
            {
                "$type": "Event+EventEntry+EventEntry_Question, Assembly-CSharp",
                "label":"br_choice",
                "question":"RequestRelationshipChange_event_ev01",
                "options":[
                    {   
                        "option": "RequestRelationshipChange_event_ev01_op01",
                        "Results": [{ "Type":"ExecuteCallbackPermissive", "arguments":["accept"] },
                                    { "Type":"EventEnd" } ] 
                    },
                    {   
                        "option": "RequestRelationshipChange_event_ev01_op02",
                        "Results": [{ "Type":"ExecuteCallbackPermissive", "arguments":["refuse"] },
                                    { "Type":"EventEnd" }] 
                    }
                ]
            }
        ]
    }
        ]
    },
    "Dictionary":
    {
        "Entries":
        {
            "zh-cn":
            {
                "AttitudeChange":"态度变化",
                "RequestRelationshipChange":"请求变更关系",
"event_AttitudeChange_string":"【$self.name$对$target.name$的态度从$originalAttitude$转变为了$newAttitude$】",
"RequestRelationshipChange_event_ev01":"$kojotext$\n$self.name$请求将二人的关系从$original$变更为$new$",
"RequestRelationshipChange_event_ev01_op01":"同意",
"RequestRelationshipChange_event_ev01_op02":"拒绝"
            },
            "en-us":
            {
                "AttitudeChange":"Attitude Change",
                "RequestRelationshipChange":"Relationship Change Request",
"event_AttitudeChange_string":"[$self.name$'s attitude towards $target.name$ changed from $originalAttitude$ to $newAttitude$]",
"RequestRelationshipChange_event_ev01":"$kojotext$\n$self.name$ requests to change our relationship from $original$ to $new$",
"RequestRelationshipChange_event_ev01_op01":"Accept",
"RequestRelationshipChange_event_ev01_op02":"Refuse"
            }
        }
    }
}