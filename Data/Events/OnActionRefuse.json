{
    "Events": {
        "list": [
            {
                "ID": "OnAPRefuse",
                "SelfValidator":{
                    "chara_conditions":[
                        {"parameters":["exists"]}
                    ]
                },
                "events": [
    {
        "$type": "Event+EventEntry+EventEntry_Branch, Events",
        "_comment":"silent branch player/npc split",
        "options":[
            {   
                "self_chara_conditions":[
                    {"parameters":["excludePlayer"]}
                ],
                "target_chara_conditions":{
                    "evTarget":[
                        {"parameters":["exists"]}
                    ]
                },
                "option": "npc branch",
                "Results": [ { "Type":"JumpToLabel", "arguments":["","br_npc_ops"]} ] 
            },
            {      
                "self_chara_conditions":[
                    {"parameters":["isPlayer"]}
                ],
                "target_chara_conditions":{
                    "evTarget":[
                        {"parameters":["exists"]}
                    ]
                },
                "option": "player branch",
                "Results": [    { "Type":"ExecuteCallback", "arguments":["eventStart"]},
                                { "Type":"JumpToLabel", "arguments":["","br_choice"]} ] 
            },
            {      
                "option": "silent fail branch",
                "Results": [ { "Type":"JumpToLabel", "arguments":["","br_end"]} ] 
            }
        ],
        "isLast": true
    },
    {
        "$type": "Event+EventEntry+EventEntry_Branch, Events",
        "_comment":"npc handling, check auto push but default cancel",
        "label": "br_npc_ops",
        "options":[
            {   
                "option": "branch where there is callbacks",
                "Results": [ { "Type":"ExistCallbackID", "arguments":["apCallback"]},
                             { "Type":"JumpToLabel", "arguments":["","br_push"]} ] 
            },
            {   
                "option": "silent branch event, this shouldnt be displayed",
                "Results": [ { "Type":"JumpToLabel", "arguments":["","br_end"]} ] 
            }
        ]
    },
    {
        "$type": "Event+EventEntry+EventEntry_Question, Events",
        "label":"br_choice",
        "portraitRefKey":"evTarget", "portraitTagsOverride":["sorry"],
        "question":"event_OnAPRefuse_ev01",
        "options":[
            {   
                "option": "event_OnAPRefuse_ev01_op1",
                "tooltip":"apTooltip",
                "Results": [ { "Type":"JumpToLabel", "arguments":["","br_push"]} ] 
            },
            {   
                "option": "event_OnAPRefuse_ev01_op2", "isDefaultCancel":true,
                "Results": [  
                                { "Type":"JumpToLabel", "arguments":["","br_end"]} ] 
            }
        ]
    },
    {
        "$type": "Event+EventEntry+EventEntry_Line, Events",
        "label": "br_end",
        "portraitRefKey":"evTarget", "portraitTagsOverride":["sorry","awkward"],
        "isLast":true,
        "line": "event_OnAPRefuse_ev02",
        "Results": [ {"Type":"ExecuteCallback","arguments":["failCallback"]} ] 
    },
    {
        "$type": "Event+EventEntry+EventEntry_Line, Events",
        "label": "br_push",
        "line": "event_OnAPRefuse_ev03",
        "portraitRefKey":"evTarget", "portraitTagsOverride":["surprised","worry"],
        "nextEntryLabel":"br_push_ops"
    },
    {
        "$type": "Event+EventEntry+EventEntry_Branch, Events",
        "_comment":"execute callbacks (push), in case of player, add callbacks depending on option. in case of npc, predetermined callbacks.",
        "label": "br_push_ops",
        "options":[
            {                   
                "option": "pushing execution event, register ap as per requirement, and let  this shouldnt be displayed",
                "Results": [ { "Type":"ExecuteCallback", "arguments":["apCallback"]},
                             { "Type":"JumpToLabel", "arguments":["","end"]} ] 
            }
        ]
    },
    {
        "$type": "Event+EventEntry+EventEntry_Line, Events",
        "label": "end",
        "isLast": true,
        "line": ""
    }
                ]
            }
        ]
    },
    "Dictionary":
    {
        "Entries":
        {
            "zh-cn":
            {
                "event_OnAPRefuse_ev01":"$evTarget.name$拒绝了$self.name$$com_variant_name$的请求",
                "event_OnAPRefuse_ev01_op1":"强行要求",
                "event_OnAPRefuse_ev01_op2":"什么都不做",
                "event_OnAPRefuse_ev02":"$self.name$决定尊重$evTarget.name$的意见",
                "event_OnAPRefuse_ev03":"$self.name$决定向$evTarget.name$施压"
            },
            "en-us":
            {
                "event_OnAPRefuse_ev01":"$evTarget.name$ refused $self.name$'s request to $com_variant_name$",
                "event_OnAPRefuse_ev01_op1":"Insist Again",
                "event_OnAPRefuse_ev01_op2":"Let it Be",
                "event_OnAPRefuse_ev02":"$self.name$ decides to respect $evTarget.name$'s decision",
                "event_OnAPRefuse_ev03":"$self.name$ decides to insist again."
            }
        }
    }
}