{
    "Events": {
        "list": [
            {                
                "ID": "CombatSimulation",
                "SelfValidator":{
                    "chara_conditions":[
                        {"parameters":["exists"]},
                        {"parameters":["isPlayer"]},
                        {"parameters":["isConscious"]}
                    ]
                },
                "events": [
                    {
                        "$type": "Event+EventEntry+EventEntry_Branch, Assembly-CSharp",
                        "options":[
                            {   
                                "target_chara_conditions":
                                {
                                    "teammates":[{"parameters":["exists"]}]
                                },
                                "Results": [ { "Type":"JumpToLabel", "arguments":["","br_hasTeam"]} ] 
                            },
                            {   
                                "Results": [ { "Type":"JumpToLabel", "arguments":["","br_solo"]} ] 
                            }
                        ]
                    },
                    {
                        "$type": "Event+EventEntry+EventEntry_Line, Assembly-CSharp",
                        "label": "br_hasTeam",
                        "line": "CombatSimulation_event_ev01",
                        "nextEntryLabel":"end"
                    },
                    {
                        "$type": "Event+EventEntry+EventEntry_Line, Assembly-CSharp",
                        "label": "br_solo",
                        "line": "CombatSimulation_event_ev02",
                        "nextEntryLabel":"end"
                    },
                    {
                        "$type": "Event+EventEntry+EventEntry_Branch, Assembly-CSharp",
                        "label": "end",
                        "isLast": true,
                        "options":[
                        {   
                            "option": "silent branch event, this shouldnt be displayed",
                            "Results": [ { "Type":"ExecuteCallback", "arguments":["startCombat"]}] 
                        }
                        ]
                    }
                ]
            }
        ]
    },
    "Dictionary":
    {
        "Entries":
        {
            "zh-cn":
            {
"CombatSimulation":"战斗模拟",
"CombatSimulation_event_ev01":"$self.name$与$teammates.name$一同开始模拟战斗",
"CombatSimulation_event_ev02":"$self.name$开始模拟战斗"
            },
            "en-us":
            {
"CombatSimulation":"Combat Simulation",
"CombatSimulation_event_ev01":"$self.name$ starts combat training with $teammates.name$",
"CombatSimulation_event_ev02":"$self.name$ starts combat training"
            }
        }
    }
}