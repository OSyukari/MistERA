            {
"MenstruationStatus_None":"<link=\"MenstruationStatus_None_tooltip\">绝经期</link>",
"MenstruationStatus_None_tooltip":"月经周期永久停止的阶段。",

"MenstruationStatus_PrePuberty":"<link=\"MenstruationStatus_PrePuberty_tooltip\">经期前</link>",
"MenstruationStatus_PrePuberty_tooltip":"性成熟前的阶段，月经周期尚未开始。",

"MenstruationStatus_Menstrual":"<link=\"MenstruationStatus_Menstrual_tooltip\">月经期</link>",
"MenstruationStatus_Menstrual_tooltip":"月经周期的第一阶段，子宫内膜脱落并随经血排出体外。",

"MenstruationStatus_PreOvulation":"<link=\"MenstruationStatus_PreOvulation_tooltip\">卵泡期</link>",
"MenstruationStatus_PreOvulation_tooltip":"月经结束后、排卵前的阶段，卵泡逐渐发育成熟。",

"MenstruationStatus_Ovulation":"<link=\"MenstruationStatus_Ovulation_tooltip\">排卵期</link>",
"MenstruationStatus_Ovulation_tooltip":"成熟卵子从卵巢排出，进入输卵管等待受精的阶段。",

"MenstruationStatus_Rest":"<link=\"MenstruationStatus_Rest_tooltip\">黄体期</link>",
"MenstruationStatus_Rest_tooltip":"排卵后至下次月经来临前的阶段。若未受孕，月经将随之而来。",

"MenstruationStatus_Pregnant":"<link=\"MenstruationStatus_Pregnant_tooltip\">妊娠中</link>",
"MenstruationStatus_Pregnant_tooltip":"卵子已受精并着床，处于妊娠状态。",

"EstrusStatus_None":"<link=\"EstrusStatus_None_tooltip\">绝情期</link>",
"EstrusStatus_None_tooltip":"发情周期永久终止的阶段。",

"EstrusStatus_PrePuberty":"<link=\"EstrusStatus_PrePuberty_tooltip\">性未成熟</link>",
"EstrusStatus_PrePuberty_tooltip":"性成熟前的阶段，发情周期尚未开始。",

"EstrusStatus_Proestrus":"<link=\"EstrusStatus_Proestrus_tooltip\">前情期</link>",
"EstrusStatus_Proestrus_tooltip":"发情周期的准备阶段，位于发情期来临之前。",

"EstrusStatus_Estrus":"<link=\"EstrusStatus_Estrus_tooltip\">发情期</link>",
"EstrusStatus_Estrus_tooltip":"发情周期的核心阶段，卵子准备就绪可供受精。",

"EstrusStatus_Interestrus":"<link=\"EstrusStatus_Interestrus_tooltip\">间情期</link>",
"EstrusStatus_Interestrus_tooltip":"两次发情期之间的休止阶段，等待下一个发情周期的开始。",

"EstrusStatus_Pregnant":"<link=\"EstrusStatus_Pregnant_tooltip\">妊娠中</link>",
"EstrusStatus_Pregnant_tooltip":"已成功受孕，处于妊娠状态。",

"humanRace_dragon_MenstruationStatus_Menstrual":"<link=\"humanRace_dragon_MenstruationStatus_Menstrual_tooltip\">繁殖前期</link>",
"humanRace_dragon_MenstruationStatus_Menstrual_tooltip":"繁殖季节来临前的准备阶段，身体逐渐进入繁殖状态。",

"humanRace_dragon_MenstruationStatus_Rest":"<link=\"humanRace_dragon_MenstruationStatus_Rest_tooltip\">休眠期</link>",
"humanRace_dragon_MenstruationStatus_Rest_tooltip":"繁殖季结束后的漫长休止阶段，生殖系统进入静止状态。"

