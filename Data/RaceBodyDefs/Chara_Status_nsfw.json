        {
            "statusID":"chara_status_pain_chara_status_pms_menstrual",
            "noDisplay":true,
            "stringFormat":"N0",
            "variantThresholdModStat":"stats_derived_painSensitivity",
            "_comment":"Pain companion, synced by Character_Trainable.TickCyclePhaseStatus via StatsManager.SyncPainCompanion: severity = abs(chara_status_pms_menstrual's own Severity). Tied thresholds -100,-60,-30,0 (severe,severe,mild,hidden) put the worse tier on the INCLUSIVE (<=) side of each boundary on the signed axis; abs() flips which side of <= a boundary value lands on, so the hidden/mild and mild/severe cutoffs here are set 0.01 below the true abs boundary (29.99/59.99, not 30/60) to keep exact boundary hits (e.g. day 2 of a 5-day phase = severity -60 = abs 60) classified the same as the tied status. First variant threshold is 0 (not the lowest real cutoff) so SeveritySet's floor (variants[0].threshold) can't clamp a legitimately-low severity up into the display range.",
            "variants":[
                { "displayable":false, "threshold":0 },
                { "displayable":false, "threshold":29.99 },
                {
                    "threshold":59.99,
                    "stat_modifiers":[
                        { "statID":"chara_status_mood", "modKey":"chara_status_pain_chara_status_pms_menstrual", "type":"setBase", "valueType":"number", "valueString":"-1" }
                    ]
                },
                {
                    "threshold":100,
                    "stat_modifiers":[
                        { "statID":"chara_status_mood", "modKey":"chara_status_pain_chara_status_pms_menstrual", "type":"setBase", "valueType":"number", "valueString":"-1" },
