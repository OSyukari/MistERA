        "Entries":
        {
            "zh-cn":
            {

"chara_status_pms_luteal": "经前期紧张",
"chara_status_pms_luteal_tooltip": "在排卵后的黄体期内随天数推移逐渐增强，黄体期结束时达到最高。数值越高，心情和精力/体力下降越多，压力上升。",

"chara_status_pms_menstrual": "经期不适",
"chara_status_pms_menstrual_tooltip": "在经期开始时最强，并随经期推移逐渐减弱。数值越高，心情和精力/体力下降越多，压力上升。",

"chara_status_pms_luteal_elf": "经前期紧张（精灵）",
"chara_status_pms_luteal_elf_tooltip": "精灵的黄体期长达约140天，因此明显症状只会在黄体期的最后约四分之一才会出现，此前大部分时间没有感觉。",

"chara_status_pms_menstrual_elf": "经期不适（精灵）",
"chara_status_pms_menstrual_elf_tooltip": "精灵的经期长达约50天，但身体不适只集中在经期开始后的头十余天，之后大部分时间没有感觉。",

"chara_status_pms": "经前综合症",
"chara_status_pms_1": "%%chara_status_pms%%：轻微",
"chara_status_pms_2": "%%chara_status_pms%%：严重",

"chara_status_pain_chara_status_pms_menstrual": "%%chara_status_pain%%（经期）",
"chara_status_pain_chara_status_pms_menstrual_elf": "%%chara_status_pain%%（经期，精灵）",
"chara_status_pain_chara_status_pms_luteal": "%%chara_status_pain%%（经前紧张）",
"chara_status_pain_chara_status_pms_luteal_elf": "%%chara_status_pain%%（经前紧张，精灵）",

"chara_status_pregnancy_t1": "孕吐",
"chara_status_pregnancy_t1_tooltip": "妊娠初期。在孕早期内每天的强度由当天进度决定（开始时最强，孕早期结束时减弱），并叠加随机波动，因人而异，时好时坏。",

"chara_status_pregnancy_t1_elf": "孕吐（精灵）",
"chara_status_pregnancy_t1_elf_tooltip": "精灵妊娠初期。强度曲线与人类相同，但随机波动改为每天重投一次而非每四小时一次——精灵会感觉「有些天特别难受，有些天还好」，而不是「一天之内时好时坏」。",

